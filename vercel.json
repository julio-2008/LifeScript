{
  "version": 2,
  "builds": [
    {
      "src": "frontend/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "frontend/web-build"
      }
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "/frontend/web-build/$1"
    }
  ],
  "outputDirectory": "frontend/web-build",
  "cleanUrls": true
}
